// Schéma Prisma pour la Boîte à Idées CSE
// Compatible MariaDB / MySQL

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// Statut d'une idée
enum IdeaStatus {
  NEW
  REVIEWING
  ACCEPTED
  REJECTED
  DONE
}

// Rôle d'un administrateur
enum AdminRole {
  MODERATOR
  ADMIN
}

// Catégorie d'idée
model Category {
  id       String  @id @default(cuid())
  name     String
  icon     String  @default("💡")
  isActive Boolean @default(true)
  ideas    Idea[]

  @@map("categories")
}

// Idée soumise par un employé
model Idea {
  id            String          @id @default(cuid())
  title         String
  description   String          @db.Text
  categoryId    String
  category      Category        @relation(fields: [categoryId], references: [id])
  isAnonymous   Boolean         @default(true)
  authorName    String?
  authorEmail   String?
  status        IdeaStatus      @default(NEW)
  adminResponse String?         @db.Text
  votesCount    Int             @default(0)
  isVisible     Boolean         @default(false)
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  votes         Vote[]
  statusHistory StatusHistory[]

  @@map("ideas")
}

// Rate limit anti-spam par IP (persistant)
model RateLimit {
  id          String   @id @default(cuid())
  ip          String
  submittedAt DateTime @default(now())

  @@index([ip, submittedAt])
  @@map("rate_limits")
}

// Vote sur une idée (anti-double-vote par token)
model Vote {
  id         String   @id @default(cuid())
  ideaId     String
  idea       Idea     @relation(fields: [ideaId], references: [id], onDelete: Cascade)
  voterToken String
  createdAt  DateTime @default(now())

  @@unique([ideaId, voterToken])
  @@map("votes")
}

// Administrateur / modérateur
model Admin {
  id            String          @id @default(cuid())
  username      String          @unique
  email         String?
  name          String
  role          AdminRole       @default(MODERATOR)
  passwordHash  String          @db.Text
  createdAt     DateTime        @default(now())
  statusChanges StatusHistory[]

  @@map("admins")
}

// Historique des changements de statut
model StatusHistory {
  id        String     @id @default(cuid())
  ideaId    String
  idea      Idea       @relation(fields: [ideaId], references: [id], onDelete: Cascade)
  oldStatus IdeaStatus
  newStatus IdeaStatus
  changedBy String
  admin     Admin      @relation(fields: [changedBy], references: [id])
  changedAt DateTime   @default(now())

  @@map("status_history")
}
